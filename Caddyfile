# Reverse proxy for the all-in-one deployment.
# Browser hits http://localhost:8080. Caddy routes API/WS/uploads to the backend
# and everything else to the Next.js frontend.
#
# For production with a real domain + automatic HTTPS, replace ":80" with your
# domain (e.g. noc.example.com) and Caddy will provision a TLS cert for you.

:80 {
	encode gzip

	# Backend REST API
	handle /api/* {
		reverse_proxy backend:4000
	}

	# WebSocket (upgrade handled automatically by Caddy)
	handle /ws* {
		reverse_proxy backend:4000
	}

	# Uploaded assets (floorplans, custom icons) served by the backend
	handle /uploads/* {
		reverse_proxy backend:4000
	}

	# Everything else -> Next.js
	handle {
		reverse_proxy frontend:3000
	}
}
