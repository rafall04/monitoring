# Reverse proxy for PROXY mode (single origin). Used only with the `proxy`
# compose profile. The site address comes from CADDY_SITE_ADDRESS, which
# deploy.sh sets:
#   :80            -> plain HTTP on port 80 (any host)         [--proxy]
#   sf.raf.my.id   -> domain with automatic HTTPS via ACME     [--proxy --tls]
#
# Caddy routes the API / WebSocket / uploads to the backend and everything else
# to the Next.js frontend, all under one origin.

{$CADDY_SITE_ADDRESS::80} {
	encode gzip

	handle /api/* {
		reverse_proxy backend:4000
	}

	handle /ws* {
		reverse_proxy backend:4000
	}

	handle /uploads/* {
		reverse_proxy backend:4000
	}

	handle {
		reverse_proxy frontend:3000
	}
}
