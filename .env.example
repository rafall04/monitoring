# =============================================================================
# MikroTik NOC - environment configuration
# Copy to `.env` and adjust. NEVER commit the real .env.
#
# For production on Ubuntu you usually DON'T edit this by hand — run
# `sudo ./deploy.sh --host <ip|domain> --backend-port 4000 --frontend-port 3000`
# which generates .env (with fresh secrets) for you. This file documents every
# variable and is handy for local `npm run dev`.
# =============================================================================

NODE_ENV=development
LOG_LEVEL=info

# ---- Public host + ports -----------------------------------------------------
# Ports published ON THE HOST (Docker maps them to the fixed container ports
# 4000/3000). PUBLIC_HOST is the IP/domain browsers use to reach the backend.
PUBLIC_HOST=localhost
BACKEND_PORT=3500
FRONTEND_PORT=3600
# Used to build the Netwatch webhook URLs shown in the UI / generated scripts.
PUBLIC_BASE_URL=http://localhost:3500
# Allowed browser origin(s), comma-separated. :3000 is the `npm run dev` frontend.
CORS_ORIGIN=http://localhost:3000,http://localhost:3600

# ---- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=noc
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=noc
# In docker-compose the host is the service name `postgres`; for local dev
# outside docker use localhost.
DATABASE_URL=postgresql://noc:change_me_postgres@localhost:5432/noc?schema=public

# ---- Redis -------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---- Backend API -------------------------------------------------------------
BACKEND_HOST=0.0.0.0

# ---- Worker ------------------------------------------------------------------
WORKER_HEALTH_PORT=4100
POLL_INTERVAL_DEFAULT_SEC=20
RECONCILE_INTERVAL_SEC=300
# Horizontal scaling: total worker instances and this instance index (0-based).
WORKER_SHARD_COUNT=1
WORKER_SHARD_INDEX=0

# ---- Auth (JWT) --------------------------------------------------------------
# Use long random strings. Generate: `openssl rand -base64 48`
JWT_ACCESS_SECRET=replace_with_long_random_string_access
JWT_REFRESH_SECRET=replace_with_long_random_string_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Credential encryption (AES-256-GCM) -------------------------------------
# 32-byte key, base64-encoded. Generate: `openssl rand -base64 32`
# Encrypts MikroTik passwords + Telegram bot tokens at rest. CHANGING THIS
# BREAKS existing encrypted rows.
CREDENTIALS_ENC_KEY=replace_with_base64_32_byte_key

# ---- Webhook (Netwatch -> backend) -------------------------------------------
# Optional comma-separated IP allowlist (router public IPs). Empty = rely on the
# per-router X-Webhook-Token only.
WEBHOOK_IP_ALLOWLIST=

# ---- Uploads (floorplans, custom icons) --------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=8

# ---- Seed (first super_admin) ------------------------------------------------
SUPER_ADMIN_EMAIL=admin@noc.local
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_NAME=Super Admin
# Set to true to also seed demo company/sites/devices (handy for local dev).
SEED_DEMO=false

# ---- Frontend (Next.js) ------------------------------------------------------
# Browser-exposed, INLINED AT BUILD TIME (passed as docker build args). Point
# these at the backend's public URL (http://PUBLIC_HOST:BACKEND_PORT).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3500
NEXT_PUBLIC_WS_URL=ws://localhost:3500/ws

# Telegram alerting is configured per-site in the UI (Admin -> Sites), not here.
