// =============================================================================
// MikroTik NOC - data model
// Hierarchy: Company -> Site -> RouterMikrotik -> Device (host watched by Netwatch)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  sites Site[]

  @@map("company")
}

model Site {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name              String
  region            String? // kabupaten / regency — groups factories in the global overview
  mapMode           String  @default("geo") // geo | floorplan
  floorplanImageUrl String?
  floorplanWidth    Int?
  floorplanHeight   Int?
  imageBounds       Json? // [[y0,x0],[y1,x1]] for CRS.Simple
  geoCenterLat      Float?
  geoCenterLng      Float?
  defaultZoom       Int     @default(13)

  telegramMode         String  @default("off") // off | server | router
  telegramChatId       String?
  telegramBotEncrypted String? // AES-256-GCM bot token, never exposed to clients

  createdAt DateTime @default(now())

  routers RouterMikrotik[]
  areas   Area[]
  devices Device[]

  @@index([companyId])
  @@map("site")
}

// An organizational zone within a factory: either a set of production Lines
// (kind="lines", e.g. Assembly) or a flat room (kind="room", e.g. QC, Server).
model Area {
  id         String   @id @default(cuid())
  siteId     String
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name       String
  kind       String   @default("lines") // lines | room
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())

  lines   Line[]
  devices Device[]

  @@index([siteId])
  @@map("area")
}

// An ordered production line inside an Area (Line A, Line B, …).
model Line {
  id         String   @id @default(cuid())
  areaId     String
  area       Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  name       String
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())

  devices Device[]

  @@index([areaId])
  @@map("line")
}

model RouterMikrotik {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  name              String
  host              String
  apiPort           Int      @default(8728)
  useTls            Boolean  @default(false)
  username          String
  passwordEncrypted String // AES-256-GCM, never exposed to clients
  routerosVersion   String   @default("v6") // v6 | v7
  pollIntervalSec   Int?
  webhookToken      String   @unique
  status            String   @default("unknown") // online | offline | unknown
  lastSeenAt        DateTime?
  resourceCache     Json?

  createdAt DateTime @default(now())

  devices Device[]

  @@index([siteId])
  @@map("router_mikrotik")
}

model Device {
  id       String         @id @default(cuid())
  routerId String
  router   RouterMikrotik @relation(fields: [routerId], references: [id], onDelete: Cascade)
  siteId   String
  site     Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  areaId   String?
  area     Area?          @relation(fields: [areaId], references: [id], onDelete: SetNull)
  lineId   String?
  line     Line?          @relation(fields: [lineId], references: [id], onDelete: SetNull)

  name           String
  ipAddress      String?
  type           String   @default("other")
  iconKey        String? // key into built-in icon library
  iconUrl        String? // custom uploaded icon
  geoLat         Float? // geo maps
  geoLng         Float?
  mapX           Float? // floorplan maps (CRS.Simple units)
  mapY           Float?
  status         String   @default("unknown") // up | down | unknown
  statusSince    DateTime?
  manualOverride String? // null | maintenance
  netwatchSynced Boolean  @default(false)
  isCritical     Boolean  @default(false)
  orderIndex     Int      @default(0) // position within its line/room
  note           String?

  // Incident workflow: an acknowledged incident is "seen, working on it" (still
  // counts as down). A silenced device suppresses alerts until `silencedUntil`,
  // e.g. while a tech is on-site fixing things.
  ackBy          String?
  ackAt          DateTime?
  silencedUntil  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusEvents StatusEvent[]

  @@index([siteId])
  @@index([routerId])
  @@index([routerId, ipAddress])
  @@index([siteId, status])
  @@index([lineId])
  @@index([areaId])
  @@map("device")
}

model StatusEvent {
  id         String   @id @default(cuid())
  deviceId   String
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  oldStatus  String
  newStatus  String
  source     String // webhook | polling | manual
  occurredAt DateTime @default(now())

  @@index([deviceId, occurredAt])
  @@map("status_event")
}

model AppUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("user") // user | operator | super_admin
  scopeSiteIds Json     @default("[]")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@map("app_user")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique // sha256 of the opaque refresh token
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_token")
}

model AuditLog {
  id       String   @id @default(cuid())
  userId   String?
  user     AppUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
  action   String
  entity   String
  entityId String?
  before   Json?
  after    Json?
  ip       String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
  @@map("audit_log")
}

// Global NOC configuration. Single row (id = "global"). Includes white-label
// branding (org name, logo, accent color, default theme) and operational
// defaults (poll interval, retention, default map view).
model Setting {
  id                 String   @id @default("global")
  orgName            String   @default("RAF NOC")
  logoUrl            String?
  // RGB channel triplet e.g. "59 130 246" — consumed via CSS var --accent so
  // alpha utilities (bg-accent/20) keep working.
  accentRgb          String   @default("59 130 246")
  themeDefault       String   @default("dark") // dark | light
  defaultMapLat      Float    @default(-6.2)
  defaultMapLng      Float    @default(106.8)
  defaultMapZoom     Int      @default(13)
  defaultPollSec     Int      @default(20)
  eventRetentionDays Int      @default(90)
  auditRetentionDays Int      @default(180)

  // Netwatch defaults pushed onto routers by add-device + sync.
  netwatchIntervalSec  Int  @default(10)
  netwatchTimeoutMs    Int  @default(1000)
  // Free-form RouterOS code appended AFTER the NOC webhook fetch. Optional —
  // for LED triggers, logging, extra fetches, etc. The webhook itself is
  // always generated by NOC so monitoring never breaks.
  netwatchExtraUp      String?
  netwatchExtraDown    String?

  // Telegram alert templates with placeholders: {device} {ip} {site} {status}
  // {when}. Used by BOTH server-mode notify and router-mode Netwatch script.
  telegramDownTemplate String @default("🔴 DOWN — {device} ({ip})\n🏭 {site}")
  telegramUpTemplate   String @default("🟢 RECOVERED — {device} ({ip})\n🏭 {site}")

  updatedAt          DateTime @updatedAt

  @@map("setting")
}

// =============================================================================
// Ruijie / Reyee Cloud integration (separate from the MikroTik spine).
// A cloud ACCOUNT (one app_id/secret) exposes many devices; the worker polls it
// READ-ONLY for per-router online status + connected-client counts. Different
// vendor/ecosystem from RouterMikrotik (no Netwatch/webhook/binary-API), so it
// gets its own models rather than overloading RouterMikrotik.
// =============================================================================
model RuijieAccount {
  id                 String    @id @default(cuid())
  label              String    @default("Ruijie Cloud")
  appId              String
  appSecretEncrypted String // AES-256-GCM, never exposed to clients
  baseUrl            String    @default("https://cloud-as.ruijienetworks.com")
  pollIntervalSec    Int? // null = use the default
  // Ruijie group_ids the NOC monitors. The account is the owner's PERSONAL one and
  // mixes many sites; the poller only stores devices in these groups (e.g. the
  // school), so non-NOC sites never reach our DB/UI. Empty = monitor nothing.
  monitoredGroupIds  String[]  @default([])
  // Map of Ruijie project (groupName) -> NOC siteId, so the Site page can
  // surface that project's AP + connected-client counts. {} = none mapped.
  groupSiteMap       Json      @default("{}")
  lastPolledAt       DateTime?
  lastError          String? // last poll failure message, for the admin UI
  createdAt          DateTime  @default(now())

  routers RuijieRouter[]

  @@map("ruijie_account")
}

model RuijieRouter {
  id        String        @id @default(cuid())
  accountId String
  account   RuijieAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  cloudSerial   String // serialNumber in Ruijie Cloud (stable id)
  cloudGroupId  String // BUILDING group_id — used for the on-demand client drill-down
  groupName     String // project/room name, for grouping in the UI
  name          String // aliasName
  model         String? // productClass, e.g. EW1300G
  online        Boolean   @default(false)
  clientCount   Int       @default(0) // staNums
  activeClients Int       @default(0) // staActiveNums
  localIp       String?
  wanIp         String?
  mac           String?
  firmware      String?
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([accountId, cloudSerial])
  @@index([accountId])
  @@map("ruijie_router")
}
